											<div class="card mb-5 mb-xl-8 w-100">
												<!--begin::Card body-->
												<div class="card-body pt-15">
													<!--begin::Summary-->
													<div class="d-flex flex-center flex-column mb-5">
														<!--begin::Avatar-->
														<div class="symbol symbol-100px symbol-circle mb-7">

														<%= image_tag user.image.url, class: 'w-100' if user.image? %>
														<% if !user.image? %>
														<img class="w-100" src="https://avatar.iran.liara.run/username?username=<%=user.name %>+<%= user.lastname %>">
														<% end %>
														</div>
														<!--end::Avatar-->
														<!--begin::Name-->
														<a href="#" class="fs-3 text-gray-800 text-hover-primary fw-bold mb-1"><%= @user.full_name %></a>
														<!--end::Name-->
														<!--begin::Position-->
														<div class="fs-5 fw-semibold text-muted mb-6"><%= @user.role %></div>
														<!--end::Position-->
														<!--begin::Info-->

														<div  style="display: none !important;" class="d-flex flex-wrap flex-center">
															<!--begin::Stats-->
															<div class="d-flex flex-column align-items-center border border-gray-300 border-dashed rounded py-3 px-3 mb-3">
																<div class="fs-4 fw-bold text-gray-700 text-center" style="width: 50px;">
																  <span></span>
																</div>
                              								  <div class="fw-semibold text-muted">years</div>
															</div>
															<!--end::Stats-->
															<!--begin::Stats-->
															<div class="d-flex flex-column align-items-center border border-gray-300 border-dashed rounded py-3 px-3 mx-4 mb-3">
																<div class="fs-4 fw-bold text-gray-700 text-center" style="width: 50px;">
																	<span class="w-50px"></span>
																</div>
																<div class="fw-semibold text-muted">cm</div>
															</div>
															<!--end::Stats-->
															<!--begin::Stats-->
															<div class="d-flex flex-column align-items-center border border-gray-300 border-dashed rounded py-3 px-3 mb-3">
																<div class="fs-4 fw-bold text-gray-700 text-center" style="width: 50px;">
																	<span class="w-50px"></span>
																</div>
																<div class="fw-semibold text-muted">kg</div>
															</div>
															<!--end::Stats-->
														</div>
														<!--end::Info-->
													</div>
													<!--end::Summary-->
													<!--begin::Details toggle-->
													<div class="d-flex flex-stack fs-4 py-3">
														<div class="fw-bold rotate collapsible" data-bs-toggle="collapse" href="#kt_customer_view_details" role="button" aria-expanded="false" aria-controls="kt_customer_view_details">Detalles 
														<span class="ms-2 rotate-180">
															<i class="ki-duotone ki-down fs-3"></i>
														</span></div>
														<span data-bs-toggle="tooltip" data-bs-trigger="hover" title="Edit user details">
                            							  <%= link_to "Editar", edit_user_path(id: user.id), class: "btn btn-sm btn-light-primary" %>
														</span>
													</div>
													<!--end::Details toggle-->
													<div class="separator separator-dashed my-3"></div>
													<!--begin::Details content-->
													<div id="kt_customer_view_details" class="collapse show">
														<div class="py-5 fs-6">
															<!--begin::Badge-->
															<!--<div class="badge badge-light-info d-inline">Premium user</div>-->
															<!--begin::Badge-->
															<!--begin::Details item-->
															<div class="fw-bold mt-5">ID usuario</div>
															<div class="text-gray-600"><%= @user.id %></div>
															<!--begin::Details item-->
															<!--begin::Details item-->
															<div class="fw-bold mt-5">Email</div>
															<div class="text-gray-600">
																<a href="#" class="text-gray-600 text-hover-primary"><%= @user.email %></a>
															</div>
															<!--begin::Details item-->
															<!--begin::Details item-->



															<!--begin::Details item-->
															<!--begin::Details item-->
															<div class="fw-bold mt-5">Registrado</div>
															<div class="text-gray-600"><%= @user.created_at.strftime("%d-%m-%Y %H:%Mh") %></div>
															<!--begin::Details item-->
															<!--begin::Details item-->

															<!--begin::Details item-->
														</div>
													</div>
													<!--end::Details content-->
												</div>
												<!--end::Card body-->
											</div>

