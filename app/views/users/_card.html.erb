<div class="card mb-5 mb-xl-8 w-100">
	<div class="card-body">
		<div class="d-flex flex-center flex-column mb-5">
			<div class="text-end w-100">
				<%= user_status_badge(user) %>
			</div>
			<div class="symbol symbol-100px symbol-circle mb-7">
				<% if user.image? %>
					<%= image_tag user.image.url, class: 'w-100' if user.image? %>
				<% else %>
					<img
						src="https://ui-avatars.com/api/?background=random&rounded=true&name=<%= @user.name %>+<%= @user.lastname %>"
						alt="iniciales usuario"
					>
				<% end %>
			</div>

			<div class="fs-3 text-gray-800 text-hover-primary fw-bold mb-1">
				<%= @user.full_name %>
			</div>

			<div class="fs-5 fw-semibold text-muted mb-6">
				<%= @user.role_text %>
			</div>
		</div>

		<div class="d-flex flex-stack fs-4 py-3">
			<div class="fw-bold rotate collapsible"
				data-bs-toggle="collapse"
				href="#user-details"
				role="button"
				aria-expanded="false"
				aria-controls="user-details"
			>
				Detalles
				<span class="ms-3 rotate-180">
					<i class="fa-solid fa-chevron-down fs-9"></i>
				</span>
			</div>
			<%= link_to "Editar", edit_user_path(id: user.id), class: "btn btn-sm btn-light-primary" %>
		</div>

		<div class="separator separator-dashed my-3"></div>

		<div id="user-details" class="collapse show">
			<div class="py-5 fs-6">

				<div class="fw-bold mt-5">Compañía</div>
				<div class="text-gray-600"><%= @user.company.presence&.name || "-" %></div>

				<div class="fw-bold mt-5">NIF</div>
				<div class="text-gray-600"><%= @user.nif.presence || "-" %></div>

				<div class="fw-bold mt-5">Email</div>
				<div class="text-gray-600"><%= @user.email %></div>

				<div class="fw-bold mt-5">Caducidad contraseña</div>
				<div class="text-gray-600"><%= @user.date_expiration_password.presence&.strftime("%d-%m-%Y – %H:%M") || "-" %></div>

				<div class="fw-bold mt-5">ID usuario</div>
				<div class="text-gray-600"><%= @user.id %></div>

				<div class="fw-bold mt-5">Última conexión</div>
				<div class="text-gray-600"><%= @user.last_connection.presence&.strftime("%d-%m-%Y – %H:%M") || "-" %></div>

				<div class="fw-bold mt-5">Registrado</div>
				<div class="text-gray-600"><%= @user.created_at.strftime("%d-%m-%Y – %H:%Mh") %></div>

			</div>
		</div>
	</div>
</div>

