<div class="row">
  <div class="col-4">
    <%= render "card", user: @user %>
  </div>

  <div class="col-8">
    <div class="card card-body mb-6">
      <div class="d-flex justify-content-between align-items-center px-6">
        <span class="fw-bold fs-6">
          Contactos de emergencia
        </span>
        <%= link_to new_emergency_contact_path(owner_user_id: @user.id), class: "btn btn-sm btn-primary" do %>
          <i class="fa fa-plus"></i> Añadir contacto
        <% end %>
      </div>

      <%= render "emergency_contacts/index", emergency_contacts: @user.emergency_contacts %>
    </div>

    <div class="card card-body">
      <span class="fw-bold fs-6 px-6">
        Solicitudes de rescate
      </span>
      <%= render "emergency_contacts/requests", emergency_requests: @user.emergency_requests %>
    </div>

    <div class="w-100 ms-2 mt-4">
      <%= link_to "← Atrás", @target == :company ? @user.company : users_path %>
    </div>
  </div>
</div>