

<% if can? :create, User %>
<span style="width: fit-content;">
  <%= link_to new_user_path, class: "btn btn-success btn-sm fw-bold d-flex flex-row justify-content-center align-items-center", style: 'width:200px;' do %>
	<i class="fa fa-plus"></i> Nuevo usuario
  <% end %>
</span>
<% end %>

<div class="card mt-3">
<div class="card-body">

<div class="text-end mb-3">
<small>
    <%= link_to params.to_unsafe_h.merge(format: :xlsx), {style: 'color: #000000'} do %><i class="far fa-file-excel"></i> Exportar Excel <%end%>
</small>
</div>



  <%= search_form_for @q, url: users_path do |f| %>

  <div class="row">
    <div class="col col-md-6">
      <div class="input-group-prepend" style="display: flex; align-items: center">        
        <%= f.search_field :email_or_name_cont, value: @search, class: 'form-control', placeholder: "Email o nombre del usuario", style: 'width: 90%; height: 40px' %>
        <%= submit_tag("Buscar", class: 'btn btn-primary btn-outline-primary', style: 'margin-left: 10px') %>
      </div>
    </div>

    <div class="col col-md-6 text-end" style="display: flex; justify-content: space-between; align-items: center; height: 40px">
      <div class="col col-md-2 text-end">
        <small><b> Rango fechas: </b> </small>
      </div>

      <div class="col col-md-4">

        <%= f.date_field :created_at_gteq, class: 'form-control', placeholder: "Inicio", style: 'height: 40px' %>

      </div>


      <div class="col col-md-4">

        <%= f.date_field :created_at_lteq, class: 'form-control', placeholder: "Fin", style: 'height: 40px' %>

      </div>
    </div>
      

  </div>

  <hr>


  <div class="row">
    <div class="col-md-6">
      <small><b>Ordenar por:</b></small>

      <span
        style="margin-left: 5%; color: #000000"><small><%= sort_link(@q, :created_at, '<i class="fa fa-calendar"></i> Fecha'.html_safe, {style: 'color: #000000'}) %></small></span>
    </div>


    <div class="col-md-6">
      <small><b>Mostrar:</b></small>

      <span style="margin-left: 5%;"> <small><%= link_to users_path, method: 'get', style: "color: #000000" do %><i class="fa fa-times"
            aria-hidden="true"></i> Eliminar filtros<%end%></small></span>
    </div>


  </div>

  <%end%>
 </div>
</div>


<hr>

<div class="card card-body mt-3">

<div class="separator mt-3 mb- 10"></div>

<table class="table table-responsive table-hover table-striped" id="kt_datatable_zero_configuration">
		<thead>
			<tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0"><th class="w-10px pe-2 sorting_disabled" rowspan="1" colspan="1" style="width: 29.9px;" aria-label="">
				
				<th class="min-w-125px sorting" tabindex="0" aria-controls="kt_table_users" rowspan="1" colspan="1" style="width: 258.45px;" aria-label="User: activate to sort column ascending">User</th>
				<th class="min-w-125px sorting" tabindex="0" aria-controls="kt_table_users" rowspan="1" colspan="1" style="width: 150.95px;" aria-label="Role: activate to sort column ascending">Rol</th>
				<th class="min-w-125px sorting" tabindex="0" aria-controls="kt_table_users" rowspan="1" colspan="1" style="width: 150.967px;" aria-label="Email address: activate to sort column ascending">Email</th>
				<th class="min-w-125px sorting" tabindex="0" aria-controls="kt_table_users" rowspan="1" colspan="1" style="width: 199.133px;" aria-label="Joined Date: activate to sort column ascending">Registrado</th>
				<th class="text-end min-w-100px sorting_disabled" rowspan="1" colspan="1" style="width: 121.15px;" aria-label="Acciones"></th>
				<th class="text-end min-w-10px sorting_disabled" rowspan="1" colspan="1" style="width: 10px;" aria-label="Acciones"></th>
			</tr>
		</thead>

		<tbody class="text-gray-600 fw-semibold">
			<% @users.each do |user| %>
				<tr class="odd" style="height: 60px;">
					<td>
					</td>
					<td>
						<%= render "user_item", user: user, link: show_user_path(id: user.id) %>
					</td>
					<td>
						<div class="d-flex align-items-center h-100">
							<%= user.role&.titleize %>
						</div>
					</td>
					<td>
						<div class="d-flex align-items-center h-100">
							<%= user.email %>
						</div>
					</td>


					<td data-order="2023-12-20T21:23:00+01:00">
						<div class="d-flex align-items-center h-100">
							<%= user.created_at.strftime("%d-%m-%Y %H:%M") %>
						</div>
					</td>

					<td class="text-end">
						<button type="button" class="btn btn-light btn-active-light-primary dropdown-toggle dropdown-toggle-split", style: 'margin-left: 20px', data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
							Acciones
						</button>
						<div class="dropdown-menu"  style="border: 1px solid #ECECEC">

							<%= link_to "Editar", edit_user_path(id: user.id), class: 'dropdown-item' %>
							<%= link_to "Eliminar", delete_user_path(id: user.id), class:'dropdown-item', data: {turbo_method: :delete, turbo_confirm: '¿Estás seguro?' } %>
						</div>
					</td>
					<td>
<%= link_to "Eliminar", delete_user_path(id: user.id), class: 'menu-link px-3', method: :delete, data: {confirm: "¿Estás seguro?"} %>							</td>
				</tr>
            <% end %>
		</tbody>
 </table>
</div>


<div class="digg_pagination mt-3">
  <%= will_paginate @alerts, :container => false %>
</div>

