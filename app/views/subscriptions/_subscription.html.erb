<%= link_to subscription, class: "btn btn-flush w-100 w-sm-325px h-100px hover-elevate-up" do %>
  <div class="card">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center gap-4">
        <h4><%= subscription.name %></h4>
        <h4><%= subscription_status_badge subscription %></h4>
      </div>
      <div class="d-flex justify-content-between align-items-center mt-2 text-start fs-7 gap-8">
        <% count = subscription.companies.count %>
        <span class="text-primary text-nowrap"><%= count %> cliente<%= "s" if count > 1 || count == 0 %></span>
      </div>
    </div>
  </div>
<% end %>
