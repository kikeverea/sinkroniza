
<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="field">
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'form-control bg-transparent', placeholder: 'Email' %>
  </div>

  <div class="field mt-3">
    <%= f.password_field :password, autocomplete: "current-password", class: 'form-control bg-transparent', placeholder: 'Password' %>
  </div>
  <div class="actions mt-3 mb-3">
    <%= f.submit "Log in", class: 'btn btn-primary', style: 'width: 100%;' %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
