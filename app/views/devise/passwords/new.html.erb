<h6>Recuperar contraseña</h6>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.email_field :email,
      placeholder: "Correo electrónico",
      class: "form-control mt-2",
      autocomplete: "email",
      autofocus: true
    %>
  </div>

  <div class="actions">
    <%= f.submit "Enviar instrucciones", class: "btn btn-sm btn-sinkroniza mt-4" %>
  </div>
<% end %>

<div class="pt-6">
  <%= link_to "← Ir a iniciar sesión", new_session_path(resource_name) %>
</div>
