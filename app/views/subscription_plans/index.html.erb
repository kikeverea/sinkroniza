<%= link_to new_subscription_path, class: "btn btn-success btn-sm w-200px" do %>
  <i class="fa fa-plus"></i> Nueva suscripción
<% end %>

<div class="card mt-3">
  <div class="card-body pt-4">
    <div class="text-end mb-4">
      <small>
        <%= link_to params.to_unsafe_h.merge(format: :xlsx),
          class: "btn btn-flush btn-active-color-success fs-7" do
        %>
          <i class="far fa-file-excel"></i> Exportar Excel
        <% end %>
      </small>
    </div>

    <%= search_form_for @q, url: subscriptions_path do |f| %>

      <div class="row">
        <!-- Search bar -->
        <div class="col-12 col-xl-6">
          <div class="input-group-prepend d-flex align-items-center gap-2">
            <%= f.search_field :name_cont, value: @search || "",
              class: "form-control h-45px flex-grow-1",
              placeholder: "Nombre de la suscripción"
            %>
            <%= submit_tag "Buscar", class: "btn btn-primary btn-outline-primary ms-2"%>
          </div>
        </div>

        <!-- Date range -->
        <div class="col-12 col-xl-6 ps-4 ps-xl-6 pt-2 pb-6">
          <div class="d-flex align-items-center gap-4 h-40px mt-4 mt-xl-0">
            <small class="w-100 w-xl-auto">
              <b>Rango fechas:</b>
            </small>
            <div class="flex-grow-1">
              <%= f.date_field :created_at_gteq, class: "form-control h-40px", placeholder: "Inicio" %>
            </div>
            <div class="flex-grow-1">
              <%= f.date_field :created_at_lteq, class: "form-control h-40px", placeholder: "Fin" %>
            </div>
          </div>
        </div>
      </div>

      <div class="separator my-4"></div>

      <div class="row">
        <div class="col-12 col-xl-6">
          <div class="d-flex flex-wrap align-items-center gap-8 h-40px mt-8 mt-xl-0 px-2">
            <small>
              <b>Ordenar por:</b>
            </small>
            <small>
              <%= sort_link(@q, :name, '<i class="fa-solid fa-user me-1"></i> Nombre'.html_safe, class: "text-dark") %>
            </small>
            <small>
              <%= sort_link(@q, :status, '<i class="fa-solid fa-ellipsis me-1"></i> Estado'.html_safe, class: "text-dark") %>
            </small>
            <small>
              <%= sort_link(@q, :created_at, '<i class="fa-solid fa-calendar me-1"></i> Fecha Registro'.html_safe, class: "text-dark") %>
            </small>
          </div>
        </div>

        <div class="col-12 col-xl-6">
          <div class="d-flex flex-wrap align-items-center gap-8 h-40px px-2">
            <small>
              <b>Mostrar:</b>
            </small>

            <small class="flex-grow-1 text-end">
              <%= link_to subscriptions_path, class: "btn btn-flush btn-active-color-danger fs-7" do %>
                <i class="fa fa-times" aria-hidden="true"></i> Eliminar filtros
              <% end %>
            </small>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card card-body mt-5">
  <table class="table table-hover table-rounded table-striped gs-7">
    <thead>
      <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0 ">
        <th>Nombre</th>
        <th>Descripción</th>
        <th>Cantidad usuarios</th>
        <th>Estado</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @subscription_plans.each do |subscription| %>
        <tr>
          <td><%= link_to subscription.name, subscription %></td>
          <td><%= subscription.description %></td>
          <td><%= subscription.max_users %></td>
          <td><%= subscription.status %></td>

          <td class="text-end">
            <button type="button" class="btn btn-light btn-active-light-primary dropdown-toggle dropdown-toggle-split" style="margin-left: 20px" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              Acciones
            </button>
            <div class="dropdown-menu"  style="border: 1px solid #ECECEC">
                <%= link_to "Ver", subscription, class: 'dropdown-item' %>
                <%= link_to "Editar", edit_subscription_path(subscription), class: 'dropdown-item' %>
                <%= link_to "Eliminar", subscription, class:'dropdown-item', data: {turbo_method: :delete, turbo_confirm: '¿Estás seguro?' } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
