<!-- lib/templates/erb/scaffold/index.html.erb.tt -->
<div class="card card-body" id="logs">

<%= link_to new_log_path, class: "btn btn-success btn-sm", style: 'max-width:200px; width: auto;' do %>
  <i class="fa fa-plus"></i> New Log
<% end %>



<div class="separator my-10"></div>

<table id="kt_datatable_zero_configuration" class="table table-hover table-rounded table-striped gy-7 gs-7">
  <thead>
    <tr class="text-start text-muted fw-bold fs-7 text-uppercase gs-0 ">
      <th>ID</th>
              <th>User</th>
              <th>User name</th>
              <th>Action</th>
      
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @logs.each do |log| %>
    <tr>
        <td><%= log.id %></td>
                  <td><%= log.user_id %></td>
                  <td><%= log.user_name %></td>
                  <td><%= log.action %></td>
        
        <td class="text-end">
        <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">Actions 
        <i class="ki-duotone ki-down fs-5 ms-1"></i></a>
        <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-4" data-kt-menu="true">
          <div class="menu-item px-3">
             <%= link_to "Show", log, class: "menu-link px-3" %>
          </div>
          <div class="menu-item px-3">
             <%= link_to "Edit", edit_log_path(log), class: 'menu-link px-3' %>
          </div>
          <div class="menu-item px-3">
            <%= link_to "Delete", log, class: 'menu-link px-3', data: { turbo_method: :delete, turbo_confirm: "Are you sure?"} %>
          </div>
        </div>
      </td>
    </tr>
    <% end %>
  </tbody>
</table>

</div>
