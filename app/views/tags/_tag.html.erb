<%= link_to tag, class: "btn btn-flush w-100 w-sm-325px h-100px hover-elevate-up" do %>
  <div class="card">
    <div class="card-body">
      <div class="d-flex align-items-center gap-4">
        <div class="rounded-circle w-20px h-20px mb-1" style="background-color: <%= tag.color.presence || "#C9C9C9" %>">
        </div>
        <h4><%= tag.name %></h4>
      </div>
      <div class="d-flex justify-content-between align-items-center mt-2 text-start fs-7 gap-8">
        <span class="text-primary text-nowrap"><%= tag.taggings.count %> etiquetados</span>
        <% if @show_company %>
          <span class="overflow-hidden text-nowrap text-overflow-ellipsis"><%= tag.company&.name %></span>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
