<!-- lib/templates/erb/scaffold/_form.html.erb.tt -->
<% if tag.errors.any? %>
  <div class="alert alert-danger d-flex align-items-center p-5">
    <i class="fa-solid fa-xmark-circle fs-2x text-danger me-4"></i>
    <div class="d-flex flex-column">
      <h4 class="mb-1 text-danger">
        No se ha podido realizar la acción
      </h4>
      <span class="ms-4">
        <% tag.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </span>
    </div>
  </div>
<% end %>

<div class="card card-body mb-8">

  <%= form_with model: tag, data: { turbo: false } do |form| %>

          <div class="mb-4">
        
          <%= form.label :name, class: "form-label" %>
          <%= form.text_field :name, class: "form-control form-control-solid" %>
        
      </div>
          <div class="mb-4">
        
          <%= form.label :color, class: "form-label" %>
          <%= form.text_field :color, class: "form-control form-control-solid" %>
        
      </div>
          <div class="mb-4">
        
          <%= form.label :company_id, class: "form-label" %>
          <%= form.text_field :company_id, class: "form-control form-control-solid" %>
        
      </div>
    
    <div class="mt-8">
      <%= form.button "Guardar", class: "btn btn-success btn-sm" %>
      <%= link_to "Cancelar", tag.persisted? ? tag : tags_path, class: "btn btn-link btn-sm btn-color-muted btn-active-color-success ms-4" %>
    </div>
  <% end %>
</div>